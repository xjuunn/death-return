	"authors": [
		"junhsiun"
	],
	"contact": {
		"sources": "https://github.com/junhsiun/death-return"
	},
	"license": "CC0-1.0",
	"icon": "assets/death-return/icon.png",
	"environment": "*",
	"entrypoints": {
