			{
				"value": "com.junhsiun.DeathReturn",
				"adapter": "kotlin"
			}
		]
	},
	"depends": {
		"fabricloader": ">=0.16.0",
		"minecraft": ">=1.21 <=1.21.11",
		"java": ">=21",
